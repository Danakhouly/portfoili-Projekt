	partition Date_Calender_Table = calculated
		mode: import
		source =
				
				VAR StartDate = min(olist_orders_dataset[order_purchase_timestamp])
				VAR EndDate = max(olist_orders_dataset[order_purchase_timestamp])
				RETURN
				ADDCOLUMNS (
				    CALENDAR ( StartDate, EndDate ),
				    "Year", YEAR ( [Date] ),
				    "Month Number", MONTH ( [Date] ),
				    "Month Name", FORMAT ( [Date], "MMMM" ),
				    "Month Short", FORMAT ( [Date], "MMM" ),
				    "Quarter", "Q" & FORMAT ( [Date], "Q" ),
				    "Week Number", WEEKNUM ( [Date] ),
				    "Day Number", DAY ( [Date] ),
				    "Day Name", FORMAT ( [Date], "DDDD" ),
				    "Year Month", FORMAT ( [Date], "YYYY-MM" )
				)

	annotation PBI_Id = 5758a7c8f6724be9906242bd650245a2

